rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: preferences
    // Fields:
    //   - userId: string (required)
    //   - budgetLevel: string (budget, moderate, luxury)
    //   - transportPreference: list
    //   - stayPreference: string
    //   - interests: list
    //   - updatedAt: timestamp
    //
    // Collection: trips
    // Fields:
    //   - userId: string (required)
    //   - destination: string (required)
    //   - startDate: string (required)
    //   - endDate: string (required)
    //   - budget: number
    //   - transportType: string
    //   - itinerary: string
    //   - weatherInfo: string
    //   - costBreakdown: map
    //   - status: string
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "kb29022004@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidPreference(data) {
      return data.userId is string &&
             (!('budgetLevel' in data) || data.budgetLevel in ['budget', 'moderate', 'luxury']) &&
             (!('transportPreference' in data) || data.transportPreference is list) &&
             (!('interests' in data) || data.interests is list);
    }

    function isValidTrip(data) {
      return data.userId is string &&
             data.destination is string && data.destination.size() > 0 && data.destination.size() < 200 &&
             data.startDate is string &&
             data.endDate is string &&
             (!('budget' in data) || data.budget is number) &&
             (!('status' in data) || data.status in ['planning', 'confirmed', 'completed']);
    }

    match /preferences/{preferenceId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId) && isValidPreference(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isOwner(request.resource.data.userId) && isValidPreference(request.resource.data);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /trips/{tripId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId) && isValidTrip(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isOwner(request.resource.data.userId) && isValidTrip(request.resource.data);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
